@model List<SMElevate.Web.Models.Common.LoanRequest>
<div class="card"><div class="card-header"><h3 class="card-title">Rejected Requests</h3></div>
<div class="table-responsive"><table class="table table-vcenter card-table">
<thead><tr><th>Request ID</th><th>Business</th><th>Facility</th><th>Amount</th><th>Rejected Date</th><th>Rejection Reason</th><th></th></tr></thead><tbody>
@foreach (var r in Model) { var remarks = r.StatusHistory.LastOrDefault()?.Remarks;
<tr><td><strong>@r.RequestNo</strong></td><td>@r.NameOfBusiness</td><td>@r.FacilityRequested</td><td>Rs. @r.Amount.ToString("N0")</td>
<td>@(r.StatusHistory.LastOrDefault()?.CreatedAt.ToString("yyyy-MM-dd") ?? "—")</td>
<td class="text-secondary" style="max-width:200px">@(remarks?.Length > 60 ? remarks[..60] + "…" : remarks ?? "—")</td>
<td><a asp-area="Banks" asp-controller="BankRequests" asp-action="Detail" asp-route-id="@r.Id" asp-route-viewOnly="true" class="btn btn-2">View Details</a></td></tr>}
</tbody></table></div></div>