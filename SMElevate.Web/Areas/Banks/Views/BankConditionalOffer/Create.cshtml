@model SMElevate.Web.Areas.Banks.ViewModels.CreateConditionalOfferViewModel
@{ var request = ViewBag.Request as SMElevate.Web.Models.Common.LoanRequest; }
<div class="card mb-3">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col"><div class="text-secondary">Application</div><div class="h3 mb-0">@(request?.CaseId ?? request?.RequestNo)</div></div>
      <div class="col-auto"><span class="badge fs-4 p-2 bg-azure-lt">@(request?.Status?.ValueText ?? "—")</span></div>
    </div>
  </div>
</div>

<div class="card">
  <form asp-area="Banks" asp-controller="BankConditionalOffer" asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="LoanRequestId" />
    <div class="card-header"><h3 class="card-title">Issue Conditional Offer</h3></div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label asp-for="ApprovedAmount" class="form-label required">Approved Amount (Rs.)</label>
          <input asp-for="ApprovedAmount" type="number" class="form-control" step="1000" />
          <span asp-validation-for="ApprovedAmount" class="text-danger small"></span>
        </div>
        <div class="col-md-3 mb-3">
          <label asp-for="TenorMonths" class="form-label required">Tenor (months)</label>
          <input asp-for="TenorMonths" type="number" class="form-control" min="1" max="360" />
          <span asp-validation-for="TenorMonths" class="text-danger small"></span>
        </div>
        <div class="col-md-3 mb-3">
          <label asp-for="ExpiryDate" class="form-label required">Offer Expiry Date</label>
          <input asp-for="ExpiryDate" type="date" class="form-control" />
          <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
          <label asp-for="FacilityType" class="form-label">Facility Type</label>
          <input asp-for="FacilityType" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
          <label asp-for="PricingSummary" class="form-label">Pricing Summary</label>
          <input asp-for="PricingSummary" class="form-control" placeholder="e.g. KIBOR + 2%" />
        </div>
        <div class="col-md-12 mb-3">
          <label asp-for="TermsAndConditions" class="form-label">Terms &amp; Conditions</label>
          <textarea asp-for="TermsAndConditions" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-12 mb-3">
          <label asp-for="ConditionsPrecedent" class="form-label">Conditions Precedent</label>
          <textarea asp-for="ConditionsPrecedent" class="form-control" rows="3" placeholder="List of conditions that must be met before disbursement"></textarea>
        </div>
        <div class="col-md-12 mb-3">
          <label asp-for="OfferLetterFile" class="form-label">Offer Letter Document</label>
          <input asp-for="OfferLetterFile" type="file" class="form-control" accept=".pdf,.doc,.docx" />
          <small class="form-hint">PDF or Word document. Optional but recommended.</small>
        </div>
      </div>
    </div>
    <div class="card-footer text-end">
      <a asp-area="Banks" asp-controller="BankRequests" asp-action="Detail" asp-route-id="@Model.LoanRequestId" class="btn btn-2 me-2">Cancel</a>
      <button type="submit" class="btn btn-success">Issue Offer</button>
    </div>
  </form>
</div>

@section HeaderActions {
  <a asp-area="Banks" asp-controller="BankRequests" asp-action="Detail" asp-route-id="@Model.LoanRequestId" class="btn btn-2">Back to Application</a>
}
