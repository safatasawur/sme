@model SMElevate.Web.Areas.Admin.ViewModels.UserListViewModel
@using SMElevate.Web.Models.Common
@{
    var bankMemberMsg = TempData["BankMemberAdded"] as string;
}
@section HeaderActions {
  <div class="btn-list d-print-none">
    <a asp-area="Admin" asp-controller="AdminUsers" asp-action="ExportExcel"
       asp-route-roleId="@Model.FilterRoleId" asp-route-userType="@Model.FilterUserType"
       asp-route-status="@Model.FilterStatus" asp-route-search="@Model.FilterSearch"
       class="btn btn-success btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon me-1"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/><path d="M8 11h8m-8 4h5"/></svg>
      Export Excel
    </a>
    <button type="button" onclick="window.print()" class="btn btn-secondary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon me-1"><path d="M17 17h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2h-14a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2"/><path d="M17 9v-4a2 2 0 0 0-2-2h-6a2 2 0 0 0-2 2v4"/><rect x="7" y="13" width="10" height="8" rx="2"/></svg>
      Export PDF
    </button>
    <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Create" class="btn btn-primary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon me-1"><path d="M12 5l0 14"/><path d="M5 12l14 0"/></svg>
      New User
    </a>
  </div>
}

@* Filter bar *@
<div class="card mb-3 d-print-none">
  <div class="card-body py-2">
    <form method="get" asp-area="Admin" asp-controller="AdminUsers" asp-action="Index" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label mb-1 small">Role</label>
        <select name="roleId" class="form-select form-select-sm">
          <option value="">All Roles</option>
          @foreach (var role in Model.Roles)
          {
            if (Model.FilterRoleId == role.Id) { <option value="@role.Id" selected>@role.RoleName</option> }
            else { <option value="@role.Id">@role.RoleName</option> }
          }
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label mb-1 small">User Type</label>
        <select name="userType" class="form-select form-select-sm">
          <option value="">All Types</option>
          @foreach (var ut in new[] { "SME", "Bank", "SBP", "Admin" })
          {
            if (ut == Model.FilterUserType) { <option value="@ut" selected>@ut</option> }
            else { <option value="@ut">@ut</option> }
          }
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label mb-1 small">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          @if (Model.FilterStatus == "active") { <option value="active" selected>Active</option> }
          else { <option value="active">Active</option> }
          @if (Model.FilterStatus == "inactive") { <option value="inactive" selected>Inactive</option> }
          else { <option value="inactive">Inactive</option> }
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label mb-1 small">Search</label>
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Name or email..." value="@Model.FilterSearch" />
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Index" class="btn btn-secondary btn-sm">Clear</a>
      </div>
    </form>
  </div>
</div>

@* Users table *@
<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      Users
      <span class="badge bg-azure-lt ms-2">@Model.Users.Count</span>
    </h3>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th>User</th>
          <th>User Type</th>
          <th>Role</th>
          <th>Auth Mode</th>
          <th>Profile</th>
          <th>Status</th>
          <th>Last Login</th>
          <th class="w-1 d-print-none"></th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Users.Any())
        {
          <tr>
            <td colspan="9" class="text-center text-secondary py-4">No users found matching the selected filters.</td>
          </tr>
        }
        @foreach (var u in Model.Users)
        {
          var typeColor = u.UserType switch {
            UserType.Admin => "bg-purple-lt",
            UserType.Bank  => "bg-azure-lt",
            UserType.SBP   => "bg-orange-lt",
            _              => "bg-teal-lt"
          };
          var initials = u.FullName.Length > 0 ? u.FullName[0].ToString().ToUpper() : "?";
          <tr>
            <td>
              <div class="d-flex py-1 align-items-center">
                <span class="avatar avatar-sm bg-azure-lt me-2 flex-shrink-0">@initials</span>
                <div class="flex-fill">
                  <div class="fw-medium">@u.FullName</div>
                  <div class="text-secondary small">@u.EmailAddress</div>
                </div>
              </div>
            </td>
            <td><span class="badge @typeColor">@u.UserType</span> <span class="text-secondary small">@(u.Role?.RoleName ?? "—")</span></td>
            <td class="text-secondary small">@(u.AuthenticationMode ?? "—")</td>
            <td>
              @if (u.UserType == UserType.SME)
              {
                if (u.Profile is not null && u.Profile.IsVerified)
                { <span class="badge bg-green-lt text-green">Verified</span> }
                else if (u.Profile is not null)
                { <span class="badge bg-orange-lt text-orange">Pending</span> }
                else
                { <span class="badge bg-secondary-lt">Not Verified</span> }
              }
              else { <span class="text-secondary">—</span> }
            </td>
            <td>
              <span class="badge @(u.IsActive ? "bg-green-lt text-green" : "bg-red-lt text-red")">
                @(u.IsActive ? "Active" : "Inactive")
              </span>
            </td>
            <td class="text-secondary small">@(u.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
            <td class="d-print-none">
              <div class="btn-list flex-nowrap">
                <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Detail" asp-route-id="@u.Id" class="btn btn-sm">View</a>
                <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm">Edit</a>
                <form asp-area="Admin" asp-controller="AdminUsers" asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                    @(u.IsActive ? "Deactivate" : "Activate")
                  </button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@* Bank Member confirmation popup *@
@if (bankMemberMsg != null)
{
<div class="modal modal-blur fade" id="modal-bank-member" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon text-success me-1"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M9 12l2 2l4 -4"/></svg>
          Bank Member Added
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">@bankMemberMsg</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary w-100" data-bs-dismiss="modal">OK</button>
      </div>
    </div>
  </div>
</div>
}

@section Scripts {
@if (bankMemberMsg != null)
{
<script>
document.addEventListener('DOMContentLoaded', function () {
  var el = document.getElementById('modal-bank-member');
  if (el) new bootstrap.Modal(el).show();
});
</script>
}
}
