@model SMElevate.Web.Areas.Admin.ViewModels.BankFormViewModel
<form method="post" asp-antiforgery="true" class="card" novalidate>
  <div class="card-body">
    <div asp-validation-summary="All" class="alert alert-danger d-none @(ViewData.ModelState.IsValid ? "" : "d-block")"></div>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label required">Bank Name</label><input asp-for="BankName" class="form-control" /></div>
      <div class="col-md-6 mb-3"><label class="form-label required">IBAN Prefix</label><input asp-for="IBANPrefix" class="form-control" placeholder="PKxxXXXX" /></div>
    </div>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label">Bank Code</label><input asp-for="BankCode" class="form-control" /></div>
      <div class="col-md-6 mb-3"><label class="form-label required">Bank Email Address</label><input asp-for="BankEmailAddress" class="form-control" type="email" /></div>
    </div>
    <div class="mb-3"><label class="form-label">Active</label><label class="form-check"><input asp-for="IsActive" type="checkbox" class="form-check-input" /><span class="form-check-label">Active</span></label></div>
  </div>
  <div class="card-footer text-end"><a asp-area="Admin" asp-controller="AdminBanks" asp-action="Index" class="btn btn-2 me-2">Cancel</a><button type="submit" class="btn btn-primary">Save Bank</button></div>
</form>