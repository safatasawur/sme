@model List<SMElevate.Web.Models.Common.Bank>
@section HeaderActions {<a asp-area="Admin" asp-controller="AdminBanks" asp-action="Create" class="btn btn-primary btn-3">New Bank</a>}
<div class="card"><div class="card-header"><h3 class="card-title">Banks</h3></div><div class="table-responsive">
<table class="table table-vcenter card-table"><thead><tr><th>Bank</th><th>IBAN Prefix</th><th>Bank Code</th><th>Email</th><th>Status</th><th></th></tr></thead><tbody>
@foreach (var b in Model) {
<tr><td><strong>@b.BankName</strong></td><td>@b.IBANPrefix</td><td>@(b.BankCode ?? "—")</td><td class="text-secondary">@b.BankEmailAddress</td>
<td><span class="badge @(b.IsActive ? "bg-green-lt" : "bg-red-lt")">@(b.IsActive ? "Active" : "Inactive")</span></td>
<td class="text-end"><div class="btn-list flex-nowrap justify-content-end">
  <a asp-area="Admin" asp-controller="AdminBanks" asp-action="Edit" asp-route-id="@b.Id" class="btn btn-2">Edit</a>
  <a asp-area="Admin" asp-controller="AdminBanks" asp-action="Members" asp-route-id="@b.Id" class="btn btn-2">Update Members</a>
  <form asp-area="Admin" asp-controller="AdminBanks" asp-action="ToggleActive" asp-route-id="@b.Id" method="post" class="d-inline">@Html.AntiForgeryToken()
    <button type="submit" class="btn btn-2">@(b.IsActive ? "Deactivate" : "Activate")</button>
  </form>
</div></td></tr>}
</tbody></table></div></div>