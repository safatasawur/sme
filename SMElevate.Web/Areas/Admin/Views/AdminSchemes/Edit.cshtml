@model SMElevate.Web.Areas.Admin.ViewModels.SchemeFormViewModel
<form method="post" asp-antiforgery="true" class="card" novalidate>
  <div class="card-body">
    <div asp-validation-summary="All" class="alert alert-danger d-none @(ViewData.ModelState.IsValid ? "" : "d-block")"></div>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label required">Scheme Name</label><input asp-for="SchemeName" class="form-control" /></div>
      <div class="col-md-6 mb-3"><label class="form-label">Scheme Code</label><input asp-for="SchemeCode" class="form-control" /></div>
    </div>
    <div class="mb-3"><label class="form-label">Description</label><textarea asp-for="SchemeDescription" class="form-control" rows="2"></textarea></div>
    <div class="mb-3"><label class="form-label">Eligibility Criteria</label><textarea asp-for="EligibilityCriteria" class="form-control" rows="2"></textarea></div>
    <div class="row">
      <div class="col-md-3 mb-3"><label class="form-label">Start Date</label><input asp-for="StartDate" type="date" class="form-control" /></div>
      <div class="col-md-3 mb-3"><label class="form-label">End Date</label><input asp-for="EndDate" type="date" class="form-control" /></div>
      <div class="col-md-3 mb-3"><label class="form-label required">Status</label>
        <select asp-for="Status" class="form-select"><option value="Draft">Draft</option><option value="Published">Published</option><option value="Inactive">Inactive</option><option value="Archived">Archived</option></select>
      </div>
      <div class="col-md-3 mb-3"><label class="form-label">Published</label><div class="mt-2"><label class="form-check form-switch"><input asp-for="IsPublished" type="checkbox" class="form-check-input" /><span class="form-check-label">Published for EndUser</span></label></div></div>
    </div>
  </div>
  <div class="card-footer text-end"><a asp-area="Admin" asp-controller="AdminSchemes" asp-action="Index" class="btn btn-2 me-2">Cancel</a><button type="submit" class="btn btn-primary">Save Scheme</button></div>
</form>