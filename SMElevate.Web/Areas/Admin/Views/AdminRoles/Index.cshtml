@model List<SMElevate.Web.Models.Common.Role>
@section HeaderActions {<a asp-area="Admin" asp-controller="AdminRoles" asp-action="Create" class="btn btn-primary btn-3">New Role</a>}
<div class="card"><div class="card-header"><h3 class="card-title">Roles</h3></div><div class="table-responsive">
<table class="table table-vcenter card-table"><thead><tr><th>Role Name</th><th>Description</th><th>Status</th><th></th></tr></thead><tbody>
@foreach (var r in Model) {
<tr><td><strong>@r.RoleName</strong></td><td class="text-secondary">@r.Description</td>
<td><span class="badge @(r.IsActive ? "bg-green-lt" : "bg-red-lt")">@(r.IsActive ? "Active" : "Inactive")</span></td>
<td class="text-end"><div class="btn-list flex-nowrap justify-content-end">
  <a asp-area="Admin" asp-controller="AdminRoles" asp-action="Edit" asp-route-id="@r.Id" class="btn btn-2">Edit</a>
  <form asp-area="Admin" asp-controller="AdminRoles" asp-action="ToggleActive" asp-route-id="@r.Id" method="post" class="d-inline">@Html.AntiForgeryToken()
    <button type="submit" class="btn btn-2">@(r.IsActive ? "Deactivate" : "Activate")</button>
  </form>
</div></td></tr>}
</tbody></table></div></div>