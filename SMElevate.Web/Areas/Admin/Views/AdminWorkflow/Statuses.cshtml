@model List<SMElevate.Web.Models.Common.WorkflowStatus>
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Workflow Statuses <span class="badge bg-azure-lt ms-2">@Model.Count</span></h3>
  </div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr><th>#</th><th>Status Code</th><th>Name</th><th>Allowed Actors</th><th>Badge</th><th>Terminal</th><th>Order</th></tr>
      </thead>
      <tbody>
        @foreach (var s in Model) {
        <tr>
          <td class="text-secondary">@s.Id</td>
          <td><code>@s.StatusCode</code></td>
          <td>@s.StatusName</td>
          <td class="text-secondary small">@s.AllowedActorTypes</td>
          <td><span class="badge @s.ColorClass">@s.StatusName</span></td>
          <td>@(s.IsFinal ? "Yes" : "—")</td>
          <td>@s.DisplayOrder</td>
        </tr>
        }
      </tbody>
    </table>
  </div>
</div>
@section HeaderActions {
  <a asp-area="Admin" asp-controller="AdminWorkflow" asp-action="Transitions" class="btn btn-2">View Transitions</a>
  <a asp-area="Admin" asp-controller="AdminWorkflow" asp-action="DeclineReasonCodes" class="btn btn-2">Decline Reason Codes</a>
}
