@model SMElevate.Web.Models.Common.LoanRequest
@{
    var allowedTransitions = ViewBag.AllowedTransitions as List<SMElevate.Web.Models.Common.WorkflowTransition>;
    var banks = ViewBag.Banks as List<SMElevate.Web.Models.Common.Bank>;
}
<div class="card mb-3">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col">
        <div class="text-secondary">Case ID</div>
        <div class="h2 mb-0">@(Model.CaseId ?? Model.RequestNo)</div>
        <div class="text-secondary mt-1">Request No: @Model.RequestNo &nbsp;|&nbsp; Submitted: @(Model.SubmittedAt?.ToString("yyyy-MM-dd") ?? Model.CreatedAt.ToString("yyyy-MM-dd"))</div>
      </div>
      <div class="col-auto">
        <span class="badge fs-3 p-2 bg-azure-lt">@(Model.Status?.ValueText ?? "—")</span>
      </div>
    </div>
  </div>
</div>

<div class="row row-cards">
  <div class="col-lg-8">
    <!-- Business Details -->
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Business Details</h3></div>
      <div class="card-body">
        <div class="datagrid">
          <div class="datagrid-item"><div class="datagrid-title">Name of Business</div><div class="datagrid-content">@Model.NameOfBusiness</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Contact Person</div><div class="datagrid-content">@Model.ContactPerson</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Cell / Landline No.</div><div class="datagrid-content">@Model.CellOrLandlineNo</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Business Address</div><div class="datagrid-content">@Model.BusinessAddress</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Annual Sales</div><div class="datagrid-content">Rs. @Model.AnnualSales.ToString("N0")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Year of Establishment</div><div class="datagrid-content">@Model.YearOfEstablishment</div></div>
          <div class="datagrid-item"><div class="datagrid-title">No. of Employees</div><div class="datagrid-content">@Model.NoOfEmployees</div></div>
          <div class="datagrid-item"><div class="datagrid-title">NTN No.</div><div class="datagrid-content">@(Model.NTNNo ?? "N/A")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Business Premise</div><div class="datagrid-content">@Model.BusinessPremise</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Registered</div><div class="datagrid-content">@(Model.IsBusinessRegistered ? "Yes" : "No") @(Model.RegistrationAuthority != null ? $"— {Model.RegistrationAuthority}" : "")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Business Nature</div><div class="datagrid-content">@Model.BusinessNature</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Applicant Email</div><div class="datagrid-content">@Model.User?.EmailAddress</div></div>
        </div>
      </div>
    </div>

    <!-- Facility Details -->
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Facility Details</h3></div>
      <div class="card-body">
        <div class="datagrid">
          <div class="datagrid-item"><div class="datagrid-title">Facility Requested</div><div class="datagrid-content">@Model.FacilityRequested</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Type of Facility</div><div class="datagrid-content">@Model.TypeOfFacility</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Amount</div><div class="datagrid-content">Rs. @Model.Amount.ToString("N0")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Tenor</div><div class="datagrid-content">@Model.Tenor months</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Assigned Bank</div><div class="datagrid-content">@(Model.AssignedBank?.BankName ?? "Not assigned")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">IBAN / RAAST</div><div class="datagrid-content">@Model.IBANOrRaastType: @Model.IBANOrRaastValue</div></div>
        </div>
      </div>
    </div>

    <!-- Shareholders -->
    @if (Model.Shareholders?.Any() ?? false) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Shareholders</h3></div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead><tr><th>Name</th><th>CNIC</th><th>Contact</th><th>Shareholding</th></tr></thead>
          <tbody>
            @foreach (var sh in Model.Shareholders) {
            <tr><td>@sh.Name</td><td>@sh.CNIC</td><td>@sh.ContactNo</td><td>@sh.ShareholdingPercentage%</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
    }

    <!-- Bank Decision Summary -->
    @if (Model.BankDecision != null) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Bank Decision</h3></div>
      <div class="card-body">
        <div class="datagrid">
          <div class="datagrid-item"><div class="datagrid-title">Decision Type</div><div class="datagrid-content"><span class="badge @(Model.BankDecision.DecisionType == "Approved" || Model.BankDecision.DecisionType == "ConditionallyApproved" ? "bg-green-lt" : "bg-red-lt")">@Model.BankDecision.DecisionType</span></div></div>
          <div class="datagrid-item"><div class="datagrid-title">Decision Date</div><div class="datagrid-content">@Model.BankDecision.DecisionDate.ToString("yyyy-MM-dd")</div></div>
          @if (Model.BankDecision.ApprovedAmount > 0) {
          <div class="datagrid-item"><div class="datagrid-title">Approved Amount</div><div class="datagrid-content">Rs. @(Model.BankDecision.ApprovedAmount?.ToString("N0") ?? "—")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Approved Tenor</div><div class="datagrid-content">@Model.BankDecision.ApprovedTenorMonths months</div></div>
          }
          @if (Model.BankDecision.DeclineReasonCode != null) {
          <div class="datagrid-item"><div class="datagrid-title">Decline Reason</div><div class="datagrid-content">[@Model.BankDecision.DeclineReasonCode.Code] @Model.BankDecision.DeclineReasonCode.Description</div></div>
          }
          <div class="datagrid-item"><div class="datagrid-title">Remarks</div><div class="datagrid-content">@(Model.BankDecision.DecisionRemarks ?? "—")</div></div>
        </div>
      </div>
    </div>
    }

    <!-- Disbursement -->
    @if (Model.Disbursement != null) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Disbursement</h3></div>
      <div class="card-body">
        <div class="datagrid">
          <div class="datagrid-item"><div class="datagrid-title">Status</div><div class="datagrid-content">@Model.Disbursement.DisbursementStatus</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Disbursed Amount</div><div class="datagrid-content">Rs. @(Model.Disbursement.DisbursedAmount?.ToString("N0") ?? "—")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Value Date</div><div class="datagrid-content">@(Model.Disbursement.ValueDate?.ToString("yyyy-MM-dd") ?? "—")</div></div>
          <div class="datagrid-item"><div class="datagrid-title">Bank Ref</div><div class="datagrid-content">@(Model.Disbursement.BankReferenceNumber ?? "—")</div></div>
        </div>
      </div>
    </div>
    }

    <!-- Status History -->
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Status History</h3></div>
      <div class="table-responsive">
        <table class="table table-vcenter card-table">
          <thead><tr><th>Status</th><th>Actor</th><th>Remarks</th><th>Date</th></tr></thead>
          <tbody>
            @foreach (var h in Model.StatusHistory?.OrderByDescending(x => x.CreatedAt) ?? Enumerable.Empty<SMElevate.Web.Models.Common.LoanRequestStatusHistory>()) {
            <tr>
              <td><span class="badge bg-azure-lt">@(h.NewStatus?.ValueText ?? "—")</span></td>
              <td class="text-secondary small">@(h.ActorType ?? "—") @(h.ChangedBy != null ? $"— {h.ChangedBy.FullName}" : "")</td>
              <td class="text-secondary small">@(h.Remarks ?? "—")</td>
              <td class="text-secondary small">@h.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <!-- Admin Actions: Advance Status -->
    @if (allowedTransitions?.Any() ?? false) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Advance Status</h3></div>
      <form asp-area="Admin" asp-controller="AdminLoanApplications" asp-action="AdvanceStatus" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="loanRequestId" value="@Model.Id" />
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label required">New Status</label>
            <select name="toStatus" class="form-select">
              @foreach (var t in allowedTransitions) {
              <option value="@t.ToStatusCode">@t.ToStatusCode @(t.RequiresRemarks ? "(requires remarks)" : "")</option>
              }
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Remarks</label>
            <textarea name="remarks" class="form-control" rows="2"></textarea>
          </div>
        </div>
        <div class="card-footer text-end">
          <button type="submit" class="btn btn-primary">Advance Status</button>
        </div>
      </form>
    </div>
    }

    <!-- Assign Bank -->
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Assign / Reassign Bank</h3></div>
      <form asp-area="Admin" asp-controller="AdminLoanApplications" asp-action="AssignBank" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="loanRequestId" value="@Model.Id" />
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label required">Bank</label>
            <select name="newBankId" class="form-select">
              @foreach (var b in banks ?? new()) {
              <option value="@b.Id" selected="@(Model.AssignedBankId == b.Id ? "selected" : null)">@b.BankName</option>
              }
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Remarks</label>
            <textarea name="remarks" class="form-control" rows="2"></textarea>
          </div>
        </div>
        <div class="card-footer text-end">
          <button type="submit" class="btn btn-warning">Assign Bank</button>
        </div>
      </form>
    </div>

    <!-- Assessments summary -->
    @if (Model.BankAssessments?.Any() ?? false) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Assessments</h3></div>
      <div class="list-group list-group-flush">
        @foreach (var a in Model.BankAssessments) {
        <div class="list-group-item">
          <div class="fw-medium">@a.AssessmentType</div>
          <div class="text-secondary small">Status: @a.Status @(a.CompletionDate.HasValue ? $"— Completed {a.CompletionDate.Value:yyyy-MM-dd}" : "")</div>
        </div>
        }
      </div>
    </div>
    }

    <!-- Additional Info Requests -->
    @if (Model.AdditionalInfoRequests?.Any() ?? false) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Info Requests</h3></div>
      <div class="list-group list-group-flush">
        @foreach (var ir in Model.AdditionalInfoRequests) {
        <div class="list-group-item">
          <div class="fw-medium">@ir.Title</div>
          <div class="text-secondary small">Status: @ir.Status @(ir.DueDate.HasValue ? $"| Due {ir.DueDate.Value:yyyy-MM-dd}" : "")</div>
        </div>
        }
      </div>
    </div>
    }

    <!-- Conditional Offers -->
    @if (Model.ConditionalOffers?.Any() ?? false) {
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Conditional Offers</h3></div>
      <div class="list-group list-group-flush">
        @foreach (var o in Model.ConditionalOffers.OrderByDescending(x => x.IssueDate)) {
        <div class="list-group-item">
          <div class="fw-medium">@o.OfferNumber <span class="badge bg-blue-lt ms-1">@o.Status</span></div>
          <div class="text-secondary small">Rs. @o.ApprovedAmount.ToString("N0") | Expires @o.ExpiryDate.ToString("yyyy-MM-dd")</div>
        </div>
        }
      </div>
    </div>
    }
  </div>
</div>

@section HeaderActions {
  <a asp-area="Admin" asp-controller="AdminLoanApplications" asp-action="Index" class="btn btn-2">Back to List</a>
}
