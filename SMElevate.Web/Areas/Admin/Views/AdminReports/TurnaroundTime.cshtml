@model SMElevate.Web.Services.Interfaces.TurnaroundTimeReportResult
@{ var banks = ViewBag.Banks as List<SMElevate.Web.Models.Common.Bank>; }
<form method="get" class="card mb-3">
  <div class="card-body"><div class="row g-2">
    <div class="col-md-3"><input type="date" name="from" value="@ViewBag.From" class="form-control" /></div>
    <div class="col-md-3"><input type="date" name="to" value="@ViewBag.To" class="form-control" /></div>
    <div class="col-md-3"><select name="bankId" class="form-select"><option value="">All Banks</option>@foreach(var b in banks??new()){<option value="@b.Id" selected="@(ViewBag.BankId != null && ViewBag.BankId.ToString() == b.Id.ToString() ? "selected" : null)">@b.BankName</option>}</select></div>
    <div class="col-md-3"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
  </div></div>
</form>
<div class="card mb-3">
  <div class="card-header"><h3 class="card-title">Overall Average Turnaround</h3></div>
  <div class="card-body"><div class="h2 text-primary">@Model.OverallAvgDays.ToString("F1") days</div><div class="text-secondary">Average days from submission to final decision across all banks</div></div>
</div>
<div class="card">
  <div class="card-header"><h3 class="card-title">Per-Bank Turnaround Time</h3></div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>Bank</th><th>Total Cases</th><th>Avg Days to Decision</th><th>Avg Days to Disbursement</th></tr></thead>
      <tbody>
        @foreach (var r in Model.Rows.OrderBy(x => x.AvgDaysToDecision)) {
        <tr><td>@r.BankName</td><td>@r.TotalCases</td><td>@r.AvgDaysToDecision.ToString("F1")</td><td>@r.AvgDaysToDisbursement.ToString("F1")</td></tr>
        }
        @if (!Model.Rows.Any()) { <tr><td colspan="4" class="text-center text-secondary">No data.</td></tr> }
      </tbody>
    </table>
  </div>
</div>
@section HeaderActions { <a asp-area="Admin" asp-controller="AdminReports" asp-action="Index" class="btn btn-2">All Reports</a> }
