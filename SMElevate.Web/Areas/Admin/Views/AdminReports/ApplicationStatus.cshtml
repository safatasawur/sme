@model SMElevate.Web.Services.Interfaces.ApplicationStatusReportResult
@{ var banks = ViewBag.Banks as List<SMElevate.Web.Models.Common.Bank>; }
<form method="get" class="card mb-3">
  <div class="card-body">
    <div class="row g-2">
      <div class="col-md-3"><input type="date" name="from" value="@ViewBag.From" class="form-control" /></div>
      <div class="col-md-3"><input type="date" name="to" value="@ViewBag.To" class="form-control" /></div>
      <div class="col-md-3">
        <select name="bankId" class="form-select">
          <option value="">All Banks</option>
          @foreach (var b in banks ?? new()) {
            <option value="@b.Id" selected="@(ViewBag.BankId != null && ViewBag.BankId.ToString() == b.Id.ToString() ? "selected" : null)">@b.BankName</option>
          }
        </select>
      </div>
      <div class="col-md-3"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
    </div>
  </div>
</form>
<div class="card">
  <div class="card-header"><h3 class="card-title">Application Status Distribution — Total: @Model.Total</h3></div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>Status</th><th>Count</th><th>% Share</th><th>Bar</th></tr></thead>
      <tbody>
        @foreach (var r in Model.Rows.OrderByDescending(x => x.Count)) {
        <tr>
          <td><span class="badge bg-azure-lt">@r.Status</span></td>
          <td>@r.Count</td>
          <td>@r.Percentage.ToString("F1")%</td>
          <td style="min-width:120px"><div class="progress progress-sm"><div class="progress-bar" style="width:@r.Percentage%"></div></div></td>
        </tr>
        }
        @if (!Model.Rows.Any()) { <tr><td colspan="4" class="text-center text-secondary">No data for the selected filters.</td></tr> }
      </tbody>
    </table>
  </div>
</div>
@section HeaderActions { <a asp-area="Admin" asp-controller="AdminReports" asp-action="Index" class="btn btn-2">All Reports</a> }
