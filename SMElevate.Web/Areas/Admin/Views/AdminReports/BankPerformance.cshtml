@model SMElevate.Web.Services.Interfaces.BankPerformanceResult
<form method="get" class="card mb-3">
  <div class="card-body"><div class="row g-2">
    <div class="col-md-4"><input type="date" name="from" value="@ViewBag.From" class="form-control" placeholder="From" /></div>
    <div class="col-md-4"><input type="date" name="to" value="@ViewBag.To" class="form-control" placeholder="To" /></div>
    <div class="col-md-4"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
  </div></div>
</form>
<div class="card">
  <div class="card-header"><h3 class="card-title">Bank Performance</h3></div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>Bank</th><th>Assigned</th><th>Approved</th><th>Declined</th><th>Disbursed</th><th>Approval Rate</th><th>Avg TAT (days)</th></tr></thead>
      <tbody>
        @foreach (var r in Model.Rows.OrderByDescending(x => x.ApprovalRate)) {
        <tr>
          <td>@r.BankName</td><td>@r.Assigned</td><td>@r.Approved</td><td>@r.Declined</td><td>@r.Disbursed</td>
          <td><span class="badge @(r.ApprovalRate >= 60 ? "bg-green-lt" : r.ApprovalRate >= 30 ? "bg-yellow-lt" : "bg-red-lt")">@r.ApprovalRate.ToString("F1")%</span></td>
          <td>@r.AvgTATDays.ToString("F1")</td>
        </tr>
        }
        @if (!Model.Rows.Any()) { <tr><td colspan="7" class="text-center text-secondary">No data.</td></tr> }
      </tbody>
    </table>
  </div>
</div>
@section HeaderActions { <a asp-area="Admin" asp-controller="AdminReports" asp-action="Index" class="btn btn-2">All Reports</a> }
