@model SMElevate.Web.Services.Interfaces.GeographicSpreadResult
<form method="get" class="card mb-3">
  <div class="card-body"><div class="row g-2">
    <div class="col-md-4"><input type="date" name="from" value="@ViewBag.From" class="form-control" placeholder="From" /></div>
    <div class="col-md-4"><input type="date" name="to" value="@ViewBag.To" class="form-control" placeholder="To" /></div>
    <div class="col-md-4"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
  </div></div>
</form>
<div class="card">
  <div class="card-header"><h3 class="card-title">Geographic Distribution</h3><div class="card-subtitle text-secondary">Derived from last part of business address</div></div>
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead><tr><th>City / Region</th><th>Applications</th><th>Approved</th><th>Disbursed</th></tr></thead>
      <tbody>
        @foreach (var r in Model.Rows.OrderByDescending(x => x.Applications)) {
        <tr><td>@r.City</td><td>@r.Applications</td><td>@r.Approved</td><td>@r.Disbursed</td></tr>
        }
        @if (!Model.Rows.Any()) { <tr><td colspan="4" class="text-center text-secondary">No data.</td></tr> }
      </tbody>
    </table>
  </div>
</div>
@section HeaderActions { <a asp-area="Admin" asp-controller="AdminReports" asp-action="Index" class="btn btn-2">All Reports</a> }
