@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin Login - SMElevate</title>
  <link href="~/dist/css/tabler.css" rel="stylesheet" />
  <link href="~/dist/css/tabler-themes.css" rel="stylesheet" />
</head>
<body>
  <script src="~/dist/js/tabler-theme.min.js"></script>
  <div class="page page-center">
    <div class="container container-tight py-4">
      <div class="text-center mb-4">
        <span class="h1 mb-0 text-primary">SMElevate</span>
        <div class="text-secondary mt-1">Admin Portal</div>
      </div>
      <div class="card card-md">
        <div class="card-body">
          <h2 class="h2 text-center mb-4">Admin Sign In</h2>
          @if (!ViewData.ModelState.IsValid)
          {
            <div class="alert alert-danger" role="alert">
              @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
              {
                <div>@error.ErrorMessage</div>
              }
            </div>
          }
          <form method="post" asp-area="Admin" asp-controller="AdminAuth" asp-action="Login" novalidate>
            @Html.AntiForgeryToken()
            <div class="mb-3">
              <label class="form-label required">Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="admin@smeelevate.local" />
            </div>
            <div class="mb-2">
              <label class="form-label required">Password</label>
              <input type="password" name="password" class="form-control" placeholder="Password" />
            </div>
            <div class="form-footer">
              <button type="submit" class="btn btn-primary w-100">Sign In</button>
            </div>
          </form>
        </div>
      </div>
      <div class="text-center text-secondary mt-3">
        <small>Default: admin@smeelevate.local / Admin@12345</small>
      </div>
    </div>
  </div>
  <script src="~/dist/js/tabler.min.js" defer></script>
</body>
</html>
