@using Microsoft.EntityFrameworkCore
@inject SMElevate.Web.Data.ApplicationDbContext _layoutDb
@{
    string? _profileDisplayName = null;
    List<SMElevate.Web.Models.Common.BusinessProfile> _userBusinesses = new();
    if (User.Identity?.IsAuthenticated == true)
    {
        var _uidClaim = User.FindFirst("UserId")?.Value;
        if (int.TryParse(_uidClaim, out var _uid))
        {
            var _prof = await _layoutDb.EndUserProfiles
                .AsNoTracking()
                .FirstOrDefaultAsync(p => p.UserId == _uid);
            if (_prof is not null)
                _profileDisplayName = ($"{_prof.FirstName} {_prof.LastName}").Trim();
            _userBusinesses = await _layoutDb.BusinessProfiles
                .AsNoTracking()
                .Where(b => b.UserId == _uid && b.IsActive)
                .OrderByDescending(b => b.CreatedAt)
                .ToListAsync();
        }
    }
    if (string.IsNullOrWhiteSpace(_profileDisplayName))
        _profileDisplayName = User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value
                           ?? User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress")?.Value
                           ?? "User";
}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>@ViewData["Title"] - SMElevate</title>
  <link href="~/dist/css/tabler.css" rel="stylesheet" />
  <link href="~/dist/css/tabler-themes.css" rel="stylesheet" />
  <link href="~/preview/css/demo.css" rel="stylesheet" />
  <style>@@import url("https://rsms.me/inter/inter.css");</style>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>
  <a href="#content" class="visually-hidden skip-link">Skip to main content</a>
  <script src="~/dist/js/tabler-theme.min.js"></script>
  <div class="page">
    <header class="navbar navbar-expand-md d-print-none">
      <div class="container-xl">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-expanded="false">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
          <a asp-area="EndUser" asp-controller="EndUserDashboard" asp-action="Index" class="text-decoration-none">
            <span class="h2 mb-0 text-primary">SMElevate</span>
          </a>
        </div>
        <div class="navbar-nav flex-row order-md-last">
          @if (_userBusinesses.Any())
          {
            <div class="nav-item dropdown me-2">
              <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown" aria-label="Business Records">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"/></svg>
                <span class="d-none d-xl-inline ms-1">Business Records</span>
              </a>
              <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                <span class="dropdown-header">My Businesses</span>
                @foreach (var biz in _userBusinesses)
                {
                  <a class="dropdown-item" asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Details" asp-route-id="@biz.Id">
                    <span class="me-1">
                      @if (biz.BusinessVerificationStatus == SMElevate.Web.Models.Common.BusinessVerificationStatus.Verified)
                      { <span class="badge bg-success-lt">✓</span> }
                      else if (biz.BusinessVerificationStatus == SMElevate.Web.Models.Common.BusinessVerificationStatus.PartiallyVerified)
                      { <span class="badge bg-warning-lt">~</span> }
                      else
                      { <span class="badge bg-secondary-lt">!</span> }
                    </span>
                    @biz.NameOfBusiness
                  </a>
                }
                <div class="dropdown-divider"></div>
                <a class="dropdown-item" asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Index">Manage All</a>
              </div>
            </div>
          }
          <div class="nav-item dropdown">
            <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown" aria-label="Open user menu">
              <span class="avatar avatar-sm bg-primary-lt">@(_profileDisplayName.Length > 0 ? _profileDisplayName[0].ToString().ToUpper() : "U")</span>
              <div class="d-none d-xl-block ps-2">
                <div>@_profileDisplayName</div>
                <div class="mt-1 small text-secondary">EndUser</div>
              </div>
            </a>
            <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
              <a class="dropdown-item" asp-area="EndUser" asp-controller="EndUserProfile" asp-action="Index">Profile</a>
              <a class="dropdown-item" asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Index">Business Profiles</a>
              <div class="dropdown-divider"></div>
              <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="dropdown-item">Logout</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </header>
    <div class="navbar-expand-md">
      <div class="collapse navbar-collapse" id="navbar-menu">
        <div class="navbar">
          <div class="container-xl">
            <div class="row flex-column flex-md-row flex-fill align-items-center">
              <div class="col">
                <nav aria-label="Primary">
                  <ul class="navbar-nav">
                    <li class="nav-item @(ViewData["ActiveNav"] as string == "Dashboard" ? "active" : "")">
                      <a class="nav-link" asp-area="EndUser" asp-controller="EndUserDashboard" asp-action="Index">
                        <span class="nav-link-title">Dashboard</span>
                      </a>
                    </li>
                    <li class="nav-item @(ViewData["ActiveNav"] as string == "LoanRequests" ? "active" : "")">
                      <a class="nav-link" asp-area="EndUser" asp-controller="EndUserLoanRequests" asp-action="Index">
                        <span class="nav-link-title">Request a Loan</span>
                      </a>
                    </li>
                    <li class="nav-item @(ViewData["ActiveNav"] as string == "MyApplications" ? "active" : "")">
                      <a class="nav-link" asp-area="EndUser" asp-controller="EndUserLoanRequests" asp-action="MyApplications">
                        <span class="nav-link-title">My Applications</span>
                      </a>
                    </li>
                    <li class="nav-item @(ViewData["ActiveNav"] as string == "BusinessProfiles" ? "active" : "")">
                      <a class="nav-link" asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Index">
                        <span class="nav-link-title">Business Profiles</span>
                      </a>
                    </li>
                  </ul>
                </nav>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="page-wrapper">
      <div class="page-header d-print-none">
        <div class="container-xl">
          <div class="row g-2 align-items-center">
            <div class="col">
              <div class="page-pretitle">@ViewData["PreTitle"]</div>
              <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="col-auto ms-auto d-print-none">
              @await RenderSectionAsync("HeaderActions", required: false)
            </div>
          </div>
        </div>
      </div>
      <main id="content" class="page-body">
        <div class="container-xl">
          @if (TempData["Success"] is string successMsg)
          {
            <div class="alert alert-success alert-dismissible mb-3" role="alert">@successMsg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
          }
          @if (TempData["Error"] is string errorMsg)
          {
            <div class="alert alert-danger alert-dismissible mb-3" role="alert">@errorMsg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
          }
          @RenderBody()
        </div>
      </main>
      <footer class="footer footer-transparent d-print-none">
        <div class="container-xl">
          <div class="row text-center align-items-center flex-row-reverse">
            <div class="col-12 col-lg-auto mt-3 mt-lg-0">
              <ul class="list-inline list-inline-dots mb-0">
                <li class="list-inline-item">Copyright &copy; 2026 <span class="link-secondary">SMElevate</span>. All rights reserved.</li>
                <li class="list-inline-item">Digital Portal for Financing to Business Enterprises</li>
              </ul>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </div>
  <script src="~/dist/js/tabler.min.js" defer></script>
  <script src="~/preview/js/demo.min.js" defer></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
