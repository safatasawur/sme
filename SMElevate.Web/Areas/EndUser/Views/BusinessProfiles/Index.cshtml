@model List<SMElevate.Web.Models.Common.BusinessProfile>
@using SMElevate.Web.Models.Common

@section HeaderActions {
  <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Create" class="btn btn-primary">
    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Business
  </a>
}

@if (!Model.Any())
{
  <div class="empty">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-lg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"/></svg>
    </div>
    <p class="empty-title">No business profiles yet</p>
    <p class="empty-subtitle text-secondary">Add your first business profile to get started with loan applications.</p>
    <div class="empty-action">
      <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Create" class="btn btn-primary">Add Your First Business</a>
    </div>
  </div>
}
else
{
  <div class="row row-cards">
    @foreach (var b in Model)
    {
      var statusClass = b.BusinessVerificationStatus == BusinessVerificationStatus.Verified ? "bg-success-lt text-success"
                      : b.BusinessVerificationStatus == BusinessVerificationStatus.PartiallyVerified ? "bg-warning-lt text-warning"
                      : "bg-secondary-lt text-secondary";
      <div class="col-md-6 col-lg-4">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <span class="avatar me-3 bg-primary-lt">@(b.NameOfBusiness.Length > 0 ? b.NameOfBusiness[0].ToString().ToUpper() : "B")</span>
              <div>
                <div class="fw-bold">@b.NameOfBusiness</div>
                <div class="small text-secondary">@b.BusinessNature</div>
              </div>
            </div>
            <div class="datagrid datagrid-sm">
              <div class="datagrid-item"><div class="datagrid-title">Contact Person</div><div class="datagrid-content">@b.ContactPerson</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Mobile / Landline</div><div class="datagrid-content">@b.CellOrLandlineNo</div></div>
              <div class="datagrid-item"><div class="datagrid-title">Status</div><div class="datagrid-content"><span class="badge @statusClass">@b.BusinessVerificationStatus</span></div></div>
            </div>
          </div>
          <div class="card-footer d-flex gap-2">
            <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary flex-fill">View</a>
            <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary flex-fill">Edit</a>
            @if (b.BusinessVerificationStatus != BusinessVerificationStatus.Verified)
            {
              <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Verify" asp-route-id="@b.Id" class="btn btn-sm btn-warning flex-fill">Verify</a>
            }
          </div>
        </div>
      </div>
    }
  </div>
}
