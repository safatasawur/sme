@model SMElevate.Web.Areas.EndUser.ViewModels.BusinessProfileEditViewModel
@using SMElevate.Web.Models.Common

@if (Model.IsBusinessEmailVerified || Model.IsBusinessMobileVerified)
{
  <div class="alert alert-warning mb-3">
    <strong>Note:</strong> Changing your business email or mobile number will reset their verification status and require re-verification.
  </div>
}

<form asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Edit" asp-route-id="@Model.Id" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="Id" />
  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
  @await Html.PartialAsync("_BusinessForm", (SMElevate.Web.Areas.EndUser.ViewModels.BusinessProfileFormViewModel)Model)
  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-area="EndUser" asp-controller="BusinessProfiles" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>

@section Scripts {
  @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
