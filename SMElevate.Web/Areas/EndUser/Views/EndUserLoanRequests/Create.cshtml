@model SMElevate.Web.Areas.EndUser.ViewModels.LoanRequestCreateViewModel
@section HeaderActions {
  <a asp-area="EndUser" asp-controller="EndUserLoanRequests" asp-action="MyApplications" class="btn btn-2">My Applications</a>
}

@* ── Business Profile Selector ────────────────────────────────────────────── *@
@if (Model.Businesses.Any())
{
  <div class="card mb-3">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" class="icon me-2">
          <rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"/>
        </svg>
        Auto-fill from Business Profile <span class="text-secondary fw-normal">(Optional)</span>
      </h3>
    </div>
    <div class="card-body">
      <div class="row align-items-end g-3">
        <div class="col-md-6">
          <label class="form-label">Select Business</label>
          <select id="business-profile-select" class="form-select">
            <option value="">— Fill form manually —</option>
            @foreach (var biz in Model.Businesses)
            {
              <option value="@biz.Id">@biz.NameOfBusiness (@biz.BusinessVerificationStatus)</option>
            }
          </select>
        </div>
        <div class="col-auto">
          <div id="business-status" class="text-secondary small"></div>
        </div>
      </div>
      <p class="text-secondary small mt-2 mb-0">Selecting a business will auto-fill and lock the business information fields.</p>
    </div>
  </div>
}

@* ── Scheme selector ──────────────────────────────────────────────────────── *@
<div class="card mb-3" id="scheme-card" style="display:none">
  <div class="card-header">
    <h3 class="card-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" class="icon me-2">
        <rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/>
      </svg>
      Select Scheme
    </h3>
  </div>
  <div class="card-body">
    <div class="row align-items-end g-3">
      <div class="col-md-6">
        <label class="form-label required">Financing Scheme</label>
        <select id="scheme-select" class="form-select">
          <option value="">— Select a scheme —</option>
          @foreach (var s in Model.Schemes)
          {
            <option value="@s.Id">@s.SchemeName</option>
          }
        </select>
      </div>
      <div class="col-auto">
        <div id="scheme-status" class="text-secondary small"></div>
      </div>
    </div>
  </div>
</div>

@* ── Alerts ───────────────────────────────────────────────────────────────── *@
<div id="form-message" class="alert alert-important alert-danger d-none" role="alert"></div>
@if (TempData["Error"] is string errMsg)
{
  <div class="alert alert-danger alert-dismissible">
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    @errMsg
  </div>
}

@* ── Main form ────────────────────────────────────────────────────────────── *@
<form id="loan-request-form" method="post"
      asp-area="EndUser" asp-controller="EndUserLoanRequests" asp-action="Create"
      asp-antiforgery="true" autocomplete="off" novalidate>
  @Html.AntiForgeryToken()
  <input type="hidden" name="SchemeId"          id="h-scheme-id" />
  <input type="hidden" name="SchemeFormId"      id="h-form-id"   value="" />
  <input type="hidden" name="FieldValuesJson"   id="h-field-values" />
  <input type="hidden" name="BusinessProfileId" id="h-business-profile-id" />
  <input type="hidden" name="ConsentGiven"      value="true" />
  <input type="hidden" id="h-bank-id" />
  <input type="hidden" id="f-IBANOrRaastValue" />
  <div id="shareholder-hidden-fields"></div>

  @* ── Business Information ────────────────────────────────────────────── *@
  <div class="card mb-3" id="biz-info-card" style="display:none">
    <div class="card-header"><h3 class="card-title">Business Information</h3></div>
    <div class="card-body">
      <div class="row g-3">

        <div class="col-md-6">
          <label class="form-label required" for="f-NameOfBusiness">Business Name</label>
          <input type="text" id="f-NameOfBusiness" class="form-control biz-field" />
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-ContactPerson">Contact Person</label>
          <input type="text" id="f-ContactPerson" class="form-control biz-field" />
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-CellOrLandlineNo">Cell / Landline No.</label>
          <input type="text" id="f-CellOrLandlineNo" class="form-control biz-field" />
        </div>

        <div class="col-md-6">
          <label class="form-label" for="f-NTNNo">NTN No.</label>
          <input type="text" id="f-NTNNo" class="form-control biz-field" />
        </div>

        <div class="col-12">
          <label class="form-label required" for="f-BusinessAddress">Business Address</label>
          <textarea id="f-BusinessAddress" class="form-control biz-field" rows="2"></textarea>
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-AnnualSales">Annual Sales (Rs.)</label>
          <input type="number" id="f-AnnualSales" class="form-control biz-field" min="0" step="1" />
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-YearOfEstablishment">Year of Establishment</label>
          <input type="number" id="f-YearOfEstablishment" class="form-control biz-field" min="1900" max="2099" />
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-NoOfEmployees">No. of Employees</label>
          <input type="number" id="f-NoOfEmployees" class="form-control biz-field" min="0" />
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-BusinessPremise">Business Premise</label>
          <select id="f-BusinessPremise" class="form-select biz-field">
            <option value="">-- Select --</option>
            @foreach (var v in Model.BusinessPremises)
            {
              <option value="@v.ValueText">@v.ValueText</option>
            }
          </select>
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-BusinessNature">Nature of Business</label>
          <select id="f-BusinessNature" class="form-select biz-field">
            <option value="">-- Select --</option>
            @foreach (var v in Model.BusinessNatures)
            {
              <option value="@v.ValueText">@v.ValueText</option>
            }
          </select>
        </div>

        <div class="col-md-4">
          <label class="form-label required" for="f-BusinessStatus">Business Status</label>
          <select id="f-BusinessStatus" class="form-select biz-field">
            <option value="">-- Select --</option>
            @foreach (var v in Model.BusinessStatuses)
            {
              <option value="@v.ValueText">@v.ValueText</option>
            }
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-IsBusinessRegistered">Is Business Registered?</label>
          <select id="f-IsBusinessRegistered" class="form-select biz-field">
            <option value="">-- Select --</option>
            <option value="Yes">Yes</option>
            <option value="No">No</option>
          </select>
        </div>

        <div class="col-md-6" id="reg-authority-row" style="display:none">
          <label class="form-label" id="reg-authority-label" for="f-RegistrationAuthority">Registration Authority</label>
          <input type="text" id="f-RegistrationAuthority" class="form-control biz-field" />
        </div>

        <div class="col-12">
          <label class="form-label required" for="f-BusinessDescription">Business Description</label>
          <textarea id="f-BusinessDescription" class="form-control biz-field" rows="3"></textarea>
        </div>

      </div>
    </div>
  </div>

  @* ── Shareholders / Partners (read-only display from Business Profile) ── *@
  <div class="card mb-3" id="shareholders-card" style="display:none">
    <div class="card-header">
      <h3 class="card-title mb-0">Shareholders / Partners</h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr><th>Name</th><th>Contact No.</th><th>Email</th><th>CNIC</th><th>Share %</th></tr>
          </thead>
          <tbody id="sh-rows-container">
            <tr id="sh-placeholder-row">
              <td colspan="5" class="text-center text-secondary py-3">
                Select a business profile to view shareholder information.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  @* ── Bank Detail (auto-loaded from Business Profile) ─────────────────── *@
  <div class="card mb-3" id="bank-detail-card" style="display:none">
    <div class="card-header"><h3 class="card-title">Bank Detail</h3></div>
    <div class="card-body" id="bank-detail-content">
      <p class="text-secondary mb-0">Select a business profile to load bank details.</p>
    </div>
  </div>

  @* ── Facility Information ────────────────────────────────────────────── *@
  <div class="card mb-3" id="facility-card" style="display:none">
    <div class="card-header"><h3 class="card-title">Facility Information</h3></div>
    <div class="card-body">
      <div class="row g-3">

        <div class="col-md-6">
          <label class="form-label required" for="f-FacilityRequested">Facility Requested</label>
          <select id="f-FacilityRequested" class="form-select">
            <option value="">-- Select --</option>
            @foreach (var v in Model.FacilityRequestedOptions)
            {
              <option value="@v.ValueText">@v.ValueText</option>
            }
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-TypeOfFacility">Type of Facility</label>
          <select id="f-TypeOfFacility" class="form-select">
            <option value="">-- Select --</option>
            @foreach (var v in Model.FacilityTypes)
            {
              <option value="@v.ValueText">@v.ValueText</option>
            }
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-Amount">Amount (Rs.)</label>
          <input type="number" id="f-Amount" class="form-control" min="0" step="1" />
        </div>

        <div class="col-md-6">
          <label class="form-label required" for="f-Tenor">Tenor (Months)</label>
          <input type="number" id="f-Tenor" class="form-control" min="1" />
        </div>

      </div>
    </div>
  </div>

  @* ── Submit ──────────────────────────────────────────────────────────── *@
  <div class="card" id="submit-card" style="display:none">
    <div class="card-footer text-end">
      <button type="button" id="submit-btn" class="btn btn-primary" onclick="submitLoanForm()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" class="icon me-1" id="submit-icon">
          <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
          <path d="M5 13v-8a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2h-7.5"/>
          <path d="M9 13l2 2l4 -4"/>
        </svg>
        <span class="spinner-border spinner-border-sm d-none me-1" id="submit-spinner"></span>
        <span id="submit-label">Submit Application</span>
      </button>
    </div>
  </div>

</form>

@section Scripts {
<script>
(function () {
  var _isSubmitting = false;

  // ── Escape helpers ─────────────────────────────────────────────────────────
  function escHtml(s)  { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function escAttr(s)  { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/"/g,'&quot;'); }
  function g(id) { var el = document.getElementById(id); return el ? el.value : ''; }

  // ── Show / hide all form sections ─────────────────────────────────────────
  var FORM_SECTIONS = ['scheme-card', 'biz-info-card', 'bank-detail-card', 'facility-card', 'submit-card'];

  function showAllSections() {
    FORM_SECTIONS.forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.style.display = '';
    });
    // Shareholders visibility is controlled by toggleShareholders() via the change event
  }

  function hideAllSections() {
    FORM_SECTIONS.concat(['shareholders-card']).forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
  }

  // ── Scheme selector ────────────────────────────────────────────────────────
  var schemeSelect = document.getElementById('scheme-select');
  var schemeStatus = document.getElementById('scheme-status');
  if (schemeSelect) {
    schemeSelect.addEventListener('change', function () {
      document.getElementById('h-scheme-id').value = this.value;
      if (schemeStatus) schemeStatus.innerHTML = this.value
        ? '<span class="badge bg-green-lt">Scheme selected</span>' : '';
    });
  }

  // ── Errors ─────────────────────────────────────────────────────────────────
  var msgBox = document.getElementById('form-message');
  function showErr(msg) {
    msgBox.textContent = msg;
    msgBox.classList.remove('d-none');
    msgBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearErr() { msgBox.classList.add('d-none'); }

  // ── Registration Authority conditional ─────────────────────────────────────
  var isRegSelect = document.getElementById('f-IsBusinessRegistered');
  var regRow      = document.getElementById('reg-authority-row');
  var regInput    = document.getElementById('f-RegistrationAuthority');
  var regLabel    = document.getElementById('reg-authority-label');

  function toggleRegAuthority(val) {
    var show = (val === 'Yes');
    regRow.style.display = show ? '' : 'none';
    if (regLabel) regLabel.classList.toggle('required', show);
    if (regInput) { regInput.required = show; if (!show) regInput.value = ''; }
  }
  if (isRegSelect) {
    isRegSelect.addEventListener('change', function () { toggleRegAuthority(this.value); });
    toggleRegAuthority(isRegSelect.value);
  }

  // ── Shareholders (read-only, shown when Partnership) ───────────────────────
  var bizStatusSelect  = document.getElementById('f-BusinessStatus');
  var shareholdersCard = document.getElementById('shareholders-card');
  var shContainer      = document.getElementById('sh-rows-container');
  var shPlaceholder    = document.getElementById('sh-placeholder-row');

  function toggleShareholders(val) {
    shareholdersCard.style.display = (val === 'Partnership') ? '' : 'none';
  }
  if (bizStatusSelect) {
    bizStatusSelect.addEventListener('change', function () { toggleShareholders(this.value); });
    toggleShareholders(bizStatusSelect.value);
  }

  function populateShareholders(list) {
    // Remove existing data rows (keep placeholder hidden)
    shContainer.querySelectorAll('.sh-row').forEach(function (r) { r.remove(); });

    if (!list || list.length === 0) {
      if (shPlaceholder) shPlaceholder.style.display = '';
      return;
    }
    if (shPlaceholder) shPlaceholder.style.display = 'none';

    list.forEach(function (sh) {
      var tr = document.createElement('tr');
      tr.className = 'sh-row';
      tr.innerHTML =
        '<td><input type="text" class="form-control form-control-sm sh-name" readonly value="' + escAttr(sh.name) + '" /></td>' +
        '<td><input type="text" class="form-control form-control-sm sh-contact" readonly value="' + escAttr(sh.contactNo) + '" /></td>' +
        '<td><input type="email" class="form-control form-control-sm sh-email" readonly value="' + escAttr(sh.email) + '" /></td>' +
        '<td><input type="text" class="form-control form-control-sm sh-cnic" readonly value="' + escAttr(sh.cnic) + '" /></td>' +
        '<td><input type="number" class="form-control form-control-sm sh-share" readonly value="' + escAttr(sh.sharePercent != null ? String(sh.sharePercent) : '') + '" /></td>';
      shContainer.appendChild(tr);
    });
  }

  function clearShareholders() {
    shContainer.querySelectorAll('.sh-row').forEach(function (r) { r.remove(); });
    if (shPlaceholder) shPlaceholder.style.display = '';
  }

  // ── Bank Detail ────────────────────────────────────────────────────────────
  var bankDetailContent = document.getElementById('bank-detail-content');

  function updateBankDetail(biz) {
    document.getElementById('f-IBANOrRaastValue').value = biz.businessIBAN || '';
    if (biz.businessBankId) {
      document.getElementById('h-bank-id').value = String(biz.businessBankId);
      var html = '<div class="row g-3">';
      html += '<div class="col-md-6"><label class="form-label">Bank</label>';
      html += '<input type="text" class="form-control bg-light" readonly value="' + escAttr(biz.businessBankName) + '" /></div>';
      if (biz.businessIBAN) {
        html += '<div class="col-md-6"><label class="form-label">IBAN</label>';
        html += '<input type="text" class="form-control bg-light" readonly value="' + escAttr(biz.businessIBAN) + '" />';
        html += '<div class="form-hint">International Bank Account Number</div></div>';
      }
      html += '</div>';
      bankDetailContent.innerHTML = html;
    } else {
      document.getElementById('h-bank-id').value = '';
      bankDetailContent.innerHTML =
        '<div class="alert alert-warning mb-0 py-2">The selected business profile does not have an associated bank. ' +
        'Please update your business profile before submitting a loan request.</div>';
    }
  }

  function clearBankDetail() {
    document.getElementById('h-bank-id').value = '';
    document.getElementById('f-IBANOrRaastValue').value = '';
    bankDetailContent.innerHTML = '<p class="text-secondary mb-0">Select a business profile to load bank details.</p>';
  }

  // ── Business profile autofill ──────────────────────────────────────────────
  var BIZ_FIELDS = [
    ['nameOfBusiness',        'f-NameOfBusiness',        'text'],
    ['contactPerson',         'f-ContactPerson',         'text'],
    ['cellOrLandlineNo',      'f-CellOrLandlineNo',      'text'],
    ['ntnNo',                 'f-NTNNo',                 'text'],
    ['businessAddress',       'f-BusinessAddress',       'textarea'],
    ['annualSales',           'f-AnnualSales',           'text'],
    ['yearOfEstablishment',   'f-YearOfEstablishment',   'text'],
    ['noOfEmployees',         'f-NoOfEmployees',         'text'],
    ['businessPremise',       'f-BusinessPremise',       'select'],
    ['businessNature',        'f-BusinessNature',        'select'],
    ['businessStatus',        'f-BusinessStatus',        'select'],
    ['isBusinessRegistered',  'f-IsBusinessRegistered',  'select'],
    ['registrationAuthority', 'f-RegistrationAuthority', 'text'],
    ['businessDescription',   'f-BusinessDescription',   'textarea']
  ];

  function setFieldLocked(el, type, locked) {
    if (type === 'select') el.disabled  = locked;
    else                   el.readOnly  = locked;
    el.classList.toggle('bg-light', locked);
  }

  function applyBizDataToForm(biz) {
    BIZ_FIELDS.forEach(function (m) {
      var el = document.getElementById(m[1]);
      if (!el) return;
      var val = String(biz[m[0]] != null ? biz[m[0]] : '');
      if (m[2] === 'select') {
        Array.from(el.options).forEach(function (o) {
          if (o.value.toLowerCase() === val.toLowerCase() || o.text.toLowerCase() === val.toLowerCase())
            el.value = o.value;
        });
      } else {
        el.value = val;
      }
      setFieldLocked(el, m[2], true);
      el.dispatchEvent(new Event('change'));
    });

    populateShareholders(biz.shareholders || []);
    updateBankDetail(biz);
  }

  function clearBizAutofill() {
    BIZ_FIELDS.forEach(function (m) {
      var el = document.getElementById(m[1]);
      if (!el) return;
      el.value = '';
      setFieldLocked(el, m[2], false);
      el.dispatchEvent(new Event('change'));
    });
    clearShareholders();
    clearBankDetail();
    document.getElementById('h-business-profile-id').value = '';
    hideAllSections();
  }

  var bizSel    = document.getElementById('business-profile-select');
  var bizStatus = document.getElementById('business-status');
  if (bizSel) {
    bizSel.addEventListener('change', function () {
      var id = this.value;
      document.getElementById('h-business-profile-id').value = id || '';
      if (!id) {
        clearBizAutofill();
        if (bizStatus) bizStatus.textContent = '';
        return;
      }
      if (bizStatus) bizStatus.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Loading…';
      fetch('/EndUser/BusinessProfiles/GetForLoanRequest?id=' + id)
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (biz) {
          if (!biz) { if (bizStatus) bizStatus.textContent = 'Could not load business data.'; return; }
          applyBizDataToForm(biz);
          showAllSections();
          if (bizStatus) bizStatus.innerHTML = '<span class="badge bg-green-lt">Auto-filled</span>';
        })
        .catch(function () { if (bizStatus) bizStatus.textContent = 'Error loading business.'; });
    });
  }

  // ── Collect field values for FieldValuesJson ───────────────────────────────
  function collectFieldValues() {
    return [
      { fieldName: 'NameOfBusiness',       fieldValue: g('f-NameOfBusiness') },
      { fieldName: 'ContactPerson',         fieldValue: g('f-ContactPerson') },
      { fieldName: 'CellOrLandlineNo',      fieldValue: g('f-CellOrLandlineNo') },
      { fieldName: 'NTNNo',                 fieldValue: g('f-NTNNo') },
      { fieldName: 'BusinessAddress',       fieldValue: g('f-BusinessAddress') },
      { fieldName: 'AnnualSales',           fieldValue: g('f-AnnualSales') },
      { fieldName: 'YearOfEstablishment',   fieldValue: g('f-YearOfEstablishment') },
      { fieldName: 'NoOfEmployees',         fieldValue: g('f-NoOfEmployees') },
      { fieldName: 'BusinessPremise',       fieldValue: g('f-BusinessPremise') },
      { fieldName: 'BusinessNature',        fieldValue: g('f-BusinessNature') },
      { fieldName: 'BusinessStatus',        fieldValue: g('f-BusinessStatus') },
      { fieldName: 'IsBusinessRegistered',  fieldValue: g('f-IsBusinessRegistered') },
      { fieldName: 'RegistrationAuthority', fieldValue: g('f-RegistrationAuthority') },
      { fieldName: 'BusinessDescription',   fieldValue: g('f-BusinessDescription') },
      { fieldName: 'FacilityRequested',     fieldValue: g('f-FacilityRequested') },
      { fieldName: 'TypeOfFacility',        fieldValue: g('f-TypeOfFacility') },
      { fieldName: 'Amount',                fieldValue: g('f-Amount') },
      { fieldName: 'Tenor',                 fieldValue: g('f-Tenor') },
      { fieldName: 'AssignedBankId',        fieldValue: g('h-bank-id') },
      { fieldName: 'IBANOrRaastType',       fieldValue: 'IBAN' },
      { fieldName: 'IBANOrRaastValue',      fieldValue: g('f-IBANOrRaastValue') }
    ];
  }

  // ── Validation ─────────────────────────────────────────────────────────────
  var REQUIRED_FIELDS = [
    ['f-NameOfBusiness',      'Business Name'],
    ['f-ContactPerson',       'Contact Person'],
    ['f-CellOrLandlineNo',    'Cell / Landline No.'],
    ['f-BusinessAddress',     'Business Address'],
    ['f-AnnualSales',         'Annual Sales'],
    ['f-YearOfEstablishment', 'Year of Establishment'],
    ['f-NoOfEmployees',       'No. of Employees'],
    ['f-BusinessPremise',     'Business Premise'],
    ['f-BusinessNature',      'Nature of Business'],
    ['f-BusinessStatus',      'Business Status'],
    ['f-IsBusinessRegistered','Is Business Registered'],
    ['f-BusinessDescription', 'Business Description'],
    ['f-FacilityRequested',   'Facility Requested'],
    ['f-TypeOfFacility',      'Type of Facility'],
    ['f-Amount',              'Amount (Rs.)'],
    ['f-Tenor',               'Tenor (Months)']
  ];

  function validateForm() {
    if (!g('h-scheme-id')) { showErr('Please select a financing scheme.'); return false; }

    for (var i = 0; i < REQUIRED_FIELDS.length; i++) {
      if (!g(REQUIRED_FIELDS[i][0]).trim()) {
        showErr('Please complete: ' + REQUIRED_FIELDS[i][1]); return false;
      }
    }

    if (g('f-IsBusinessRegistered') === 'Yes' && !g('f-RegistrationAuthority').trim()) {
      showErr('Registration Authority is required when the business is registered.'); return false;
    }

    var bizProfileId = g('h-business-profile-id');
    if (bizProfileId) {
      // BP selected: must have a bank
      if (!g('h-bank-id')) {
        showErr('The selected business profile does not have an associated bank. Please update the business profile first.');
        return false;
      }
      // Partnership: must have shareholders from BP
      if (g('f-BusinessStatus') === 'Partnership') {
        var shRows = shContainer.querySelectorAll('.sh-row');
        if (shRows.length === 0) {
          showErr('The selected business profile has no shareholders. Shareholders are required for a Partnership application.');
          return false;
        }
      }
    }

    clearErr();
    return true;
  }

  // ── Submit (with duplicate prevention) ────────────────────────────────────
  var submitBtn   = document.getElementById('submit-btn');
  var submitIcon  = document.getElementById('submit-icon');
  var submitSpinner = document.getElementById('submit-spinner');
  var submitLabel = document.getElementById('submit-label');

  function setSubmitting(on) {
    _isSubmitting = on;
    submitBtn.disabled = on;
    if (submitIcon)    submitIcon.classList.toggle('d-none', on);
    if (submitSpinner) submitSpinner.classList.toggle('d-none', !on);
    if (submitLabel)   submitLabel.textContent = on ? 'Submitting Application is in Progress...' : 'Submit Application';
  }

  window.submitLoanForm = function () {
    if (_isSubmitting) return; // Guard against double-click / Enter key

    if (!validateForm()) return; // Validation failed — keep button enabled

    setSubmitting(true);

    document.getElementById('h-field-values').value = JSON.stringify(collectFieldValues());

    // Add shareholder hidden fields (server may override with BP data, but include for safety)
    var shs = Array.from(shContainer.querySelectorAll('.sh-row')).map(function (row) {
      var get = function (cls) { return (row.querySelector('.' + cls) || {}).value || ''; };
      return { name: get('sh-name'), contact: get('sh-contact'), email: get('sh-email'), cnic: get('sh-cnic'), share: get('sh-share') };
    }).filter(function (sh) { return !!sh.name; });

    var hc = document.getElementById('shareholder-hidden-fields');
    hc.innerHTML = '';
    shs.forEach(function (sh, idx) {
      function add(prop, val) {
        var inp = document.createElement('input');
        inp.type = 'hidden'; inp.name = 'Shareholders[' + idx + '].' + prop; inp.value = val;
        hc.appendChild(inp);
      }
      add('Name', sh.name); add('ContactNo', sh.contact); add('Email', sh.email);
      add('CNIC', sh.cnic); add('ShareholdingPercentage', sh.share);
    });

    // Guard: if submit fails (e.g. server validation returns the same page), re-enable button
    var form = document.getElementById('loan-request-form');
    try {
      form.submit();
    } catch (e) {
      setSubmitting(false);
      showErr('Submission failed. Please try again.');
    }
  };

  // Prevent Enter key from submitting the form twice
  document.getElementById('loan-request-form').addEventListener('submit', function (e) {
    e.preventDefault();
  });

})();
</script>
}
