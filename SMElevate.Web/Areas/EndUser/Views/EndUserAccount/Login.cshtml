@{Layout = null; ViewData["Title"] = "Sign In";}
<!doctype html><html><head><meta charset="utf-8"/><title>Sign In - SMElevate</title>
<link href="~/dist/css/tabler.css" rel="stylesheet"/>
<link href="~/dist/css/tabler-themes.css" rel="stylesheet"/>
</head>
<body><script src="~/dist/js/tabler-theme.min.js"></script>
<div class="page page-center"><div class="container container-tight py-4">

  <div class="text-center mb-4">
    <span class="h1 mb-0 text-primary">SMElevate</span>
    <div class="text-secondary mt-1">Digital Portal for Financing to Business Enterprises</div>
  </div>

  @if (TempData["Error"] is string err) {
    <div class="alert alert-danger mb-3" role="alert">@err</div>
  }
  @if (TempData["Info"] is string info) {
    <div class="alert alert-info mb-3" role="alert">@info</div>
  }

  <div class="card card-md"><div class="card-body">
    <h2 class="h2 text-center mb-4">Login to your account</h2>

    @if (!ViewData.ModelState.IsValid) {
      <div class="alert alert-danger" role="alert">
        @string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))
      </div>
    }

    <form method="post" asp-area="EndUser" asp-controller="EndUserAccount" asp-action="Login" asp-antiforgery="true" novalidate>
      @Html.AntiForgeryToken()
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input name="Email" type="email" class="form-control" placeholder="your@email.com" />
      </div>
      <div class="mb-2">
        <label class="form-label">Password</label>
        <input name="Password" type="password" class="form-control" />
      </div>
      <div class="form-footer">
        <button type="submit" class="btn btn-primary w-100">Sign in</button>
      </div>
    </form>
  </div>

  <div class="hr-text">or continue with</div>

  <div class="card-body">
    <div class="row g-2">

      <div class="col-12">
        <a href="@Url.Action("ExternalLogin", "EndUserAccount", new { area = "EndUser", provider = "Google" })"
           class="btn btn-white w-100 d-flex align-items-center justify-content-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          </svg>
          Continue with Google
        </a>
      </div>

      <div class="col-12">
        <a href="@Url.Action("ExternalLogin", "EndUserAccount", new { area = "EndUser", provider = "Apple" })"
           class="btn btn-white w-100 d-flex align-items-center justify-content-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 814 1000">
            <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 135.4-317.3 269-317.3 70.1 0 128.4 46.4 172.5 46.4 42.8 0 109.2-49 192.5-49 31 0 108.2 2.6 168.2 74.9zm-234.5-185.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/>
          </svg>
          Continue with Apple
        </a>
      </div>

      <div class="col-12">
        <a href="@Url.Action("ExternalLogin", "EndUserAccount", new { area = "EndUser", provider = "Microsoft" })"
           class="btn btn-white w-100 d-flex align-items-center justify-content-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 21 21">
            <rect x="1"  y="1"  width="9" height="9" fill="#F25022"/>
            <rect x="11" y="1"  width="9" height="9" fill="#7FBA00"/>
            <rect x="1"  y="11" width="9" height="9" fill="#00A4EF"/>
            <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
          </svg>
          Continue with Microsoft
        </a>
      </div>

    </div>
  </div></div>

  <div class="text-center text-secondary mt-3">
    Don't have an account? <a asp-area="EndUser" asp-controller="EndUserAccount" asp-action="Register">Register</a>
  </div>

</div></div>
<script src="~/dist/js/tabler.min.js" defer></script>
</body></html>
